{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>camptocamp/gs-renovate-config-preset:base.json5#1.9.3',
    'github>camptocamp/gs-renovate-config-preset:group.json5#1.9.3',
    'github>camptocamp/gs-renovate-config-preset:ci.json5#1.9.3',
    'github>camptocamp/gs-renovate-config-preset:preset.json5#1.9.3',
    'github>camptocamp/gs-renovate-config-preset:pre-commit.json5#1.9.3',
    'github>camptocamp/gs-renovate-config-preset:python.json5#1.9.3',
    'github>camptocamp/gs-renovate-config-preset:json-schema.json5#1.9.3',
    'github>camptocamp/gs-renovate-config-preset:shellcheck.json5#1.9.3',
    'github>camptocamp/gs-renovate-config-preset:own.json5#1.9.3',
    'github>camptocamp/gs-renovate-config-preset:security.json5#1.9.3',
  ],
  packageRules: [
    /** Disable upgrading the supported Python version */
    {
      matchFileNames: ['pyproject.toml', '.python-version'],
      enabled: false,
      matchDepNames: ['python'],
    },
    /** Don't allows update on ubuntu:mantic-* Docker images */
    {
      matchNewValue: '!/^[0-9][0-9]\\.[0-9][0-9]$/',
      enabled: false,
      matchDepNames: ['ubuntu'],
    },
    /** Keep setuptools below 81.0.0 for pyramid */
    {
      enabled: false,
      matchDepNames: ['setuptools'],
      allowedVersions: '<81.0.0',
    },
  ],
  regexManagers: [
    {
      fileMatch: ['^github_app_geo_project/module/updates/versions.yaml$'],
      matchStrings: [
        "'?(?<depName>[a-zA-Z0-9-_/]+)'?: '?(?<currentValue>[v0-9\\.]+)'? # (?<datasource>[a-z-]+)",
      ],
      managerFilePatterns: ['/^github_app_geo_project/module/updates/versions\\.yaml$/'],
    },
  ],
}
